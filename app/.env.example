# VMOL Protocol — environment variables
# Copy to app/.env for local dev. On Render, set these in the dashboard.

# --- LLM (OpenRouter) ---
LLM_API_KEY=sk-or-v1-your-key-here          # SECRET
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=minimax/minimax-m2.5:free

# --- Server ---
PORT=3001

# --- Starknet Sepolia ---
STARKNET_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_10/_zuaFihvvIkJ2dwMdRZ0_
AGENT_ADDRESS=0x1f8975c5a1c6d2764bd30dddf4d6ab80c59e8287e5f796a5ba2490dcbf2dab6
AGENT_PRIVATE_KEY=0x...your-agent-private-key...   # SECRET

# Deployed contracts (already on Sepolia)
POOL_ADDRESS=0x06ef0863a1353770bf483bf57e8623b262ccccdfbf183cdd086d45bbcdf85fac
GOVERNOR_ADDRESS=0x00726210f3763cb4cfffb6c6a41526a85afe47a87a8a38b2000cb96e6e569c9a
